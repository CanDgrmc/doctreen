{
  "name": "doctreen",
  "version": "1.8.0",
  "description": "Code-first API docs + OpenAPI 3.1 export + integration tests + runtime validation for Node.js. Define routes once with Zod and get docs, runnable flows, 422-on-invalid-request validation, OpenAPI 3.1 export, and schema drift detection for Express, Fastify, Hono, Koa, and NestJS.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "doctreen-flow": "./bin/doctreen-flow.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./express": {
      "types": "./src/adapters/express.d.ts",
      "default": "./src/adapters/express.js"
    },
    "./fastify": {
      "types": "./src/adapters/fastify.d.ts",
      "default": "./src/adapters/fastify.js"
    },
    "./hono": {
      "types": "./src/adapters/hono.d.ts",
      "default": "./src/adapters/hono.js"
    },
    "./koa": {
      "types": "./src/adapters/koa.d.ts",
      "default": "./src/adapters/koa.js"
    },
    "./nest": {
      "types": "./src/adapters/nest.d.ts",
      "default": "./src/adapters/nest.js"
    },
    "./zod": {
      "types": "./src/adapters/zod.d.ts",
      "default": "./src/adapters/zod.js"
    },
    "./flows": {
      "types": "./src/flows/index.d.ts",
      "default": "./src/flows/index.js"
    }
  },
  "scripts": {
    "example": "node example/app.js",
    "example:ts": "npx tsx example/app.ts",
    "example:fastify": "node example/fastify-app.js",
    "example:fastify:ts": "npx tsx example/fastify-app.ts",
    "example:hono": "npx tsx example/hono-app.js",
    "example:hono:ts": "npx tsx example/hono-app.ts",
    "example:koa": "node example/koa-app.js",
    "example:koa:ts": "npx tsx example/koa-app.ts",
    "example:nest": "npx tsx example/nest-app.ts",
    "release:callout": "node scripts/update-release-callout.js",
    "version": "node scripts/update-release-callout.js && git add README.md"
  },
  "keywords": [
    "api",
    "api-docs",
    "documentation",
    "code-first",
    "zod",
    "schema",
    "validation",
    "request-validation",
    "integration-tests",
    "openapi",
    "openapi-3-1",
    "openapi-export",
    "postman",
    "middleware",
    "express",
    "express-docs",
    "fastify",
    "fastify-docs",
    "hono",
    "hono-docs",
    "koa",
    "koa-docs",
    "nestjs",
    "nestjs-docs",
    "schema-drift"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CanDgrmc/doctreen.git"
  },
  "homepage": "https://github.com/CanDgrmc/doctreen#readme",
  "bugs": {
    "url": "https://github.com/CanDgrmc/doctreen/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "overrides": {
    "is-generator-function": "1.0.7"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.0",
    "@koa/bodyparser": "^5.1.0",
    "@koa/router": "^13.0.0",
    "@types/express": "^5.0.6",
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.0",
    "express": "^4.18.0",
    "fastify": "^5.8.4",
    "hono": "^4.7.0",
    "koa": "^2.15.0",
    "tsx": "^4.21.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.22.0"
  }
}
